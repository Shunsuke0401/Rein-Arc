# ---------------------------------------------------------------------------
# Rein on Arc — environment template
# Copy to .env.local and fill in the real values.
# ---------------------------------------------------------------------------

# Prisma / local DB ---------------------------------------------------------
DATABASE_URL="file:./dev.db"

# Arc chain -----------------------------------------------------------------
# Arc is testnet-only today. See docs.arc.network/references/connect-to-arc
# for the current testnet RPC and chain id.
ARC_RPC_URL="https://rpc.testnet.arc.network"
ARC_CHAIN_ID="28882"
NEXT_PUBLIC_ARC_CHAIN_ID="28882"

# USDC is the native gas token on Arc — the ERC-20 contract below is the
# on-chain identifier for balance reads and transfers.
# See docs.arc.network/references/contract-addresses for the current value.
USDC_CONTRACT_ARC="0x0000000000000000000000000000000000000000"

# ZeroDev -------------------------------------------------------------------
# Create a project at https://dashboard.zerodev.app/ targeting "Arc Testnet".
# Copy the generated bundler + paymaster URLs.
ZERODEV_PROJECT_ID=""
ZERODEV_BUNDLER_URL=""
ZERODEV_PAYMASTER_URL=""
NEXT_PUBLIC_ZERODEV_PROJECT_ID=""

# WebAuthn ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="Rein"

# Mock on-ramp faucet -------------------------------------------------------
# An EOA pre-funded with testnet USDC (get from https://faucet.circle.com).
# The server uses it to simulate fiat on-ramp deposits — "Add funds"
# transfers from this address to the target agent's Kernel. In production
# this becomes a real Stripe / Circle fiat on-ramp.
REIN_ONRAMP_FUNDER_PRIVATE_KEY=""
REIN_ONRAMP_FUNDER_ADDRESS=""

# At-rest encryption for session-key ciphertext -----------------------------
# 32-byte hex (64 characters). Generate with:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
APP_ENCRYPTION_KEY=""
