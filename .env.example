# ---------------------------------------------------------------------------
# Rein — environment template
# Copy to .env.local and fill in real values for the chain you're running on.
# ---------------------------------------------------------------------------

# Prisma / local DB ---------------------------------------------------------
# Local dev: `file:./dev.db`.
# Railway (with /data volume mount): `file:/data/dev.db`.
DATABASE_URL="file:./dev.db"

# Chain ---------------------------------------------------------------------
# Every value below is required at boot. There are no chain-specific
# defaults — supplying a complete env is how you target a specific chain.
# Example values shown for Base Sepolia (chain id 84532).
CHAIN_ID="84532"
CHAIN_NAME="Base Sepolia"
CHAIN_RPC_URL="https://sepolia.base.org"
EXPLORER_URL="https://sepolia.basescan.org"

# Stable token (ERC-20). Per-payment caps and balances are denominated in
# this token. STABLE_DECIMALS is usually 6 for USDC.
STABLE_CONTRACT="0x036CbD53842c5426634e7929541eC2318f3dCF7e"
STABLE_SYMBOL="USDC"
STABLE_DECIMALS="6"

# ZeroDev -------------------------------------------------------------------
# Create a project at https://dashboard.zerodev.app/ and enable the chain
# above for that project. The bundler + paymaster URLs are derived from
# ZERODEV_PROJECT_ID + CHAIN_ID at runtime — no separate URL envs needed.
ZERODEV_PROJECT_ID=""

# Rate-limit policy variant -------------------------------------------------
# auto         pick the rolling-window contract if it's deployed on this
#              chain, else fall back to a lifetime count cap.
# with-reset   require the rolling-window contract; refuse to install if
#              it isn't deployed.
# lifetime     always use the lifetime count cap (no rolling window).
RATE_LIMIT_VARIANT="auto"

# WebAuthn ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="Rein"

# At-rest encryption for session-key ciphertext -----------------------------
# 32-byte hex (64 characters). Generate with:
#   node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
APP_ENCRYPTION_KEY=""
