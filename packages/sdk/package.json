{
  "name": "rein-sdk",
  "version": "0.2.0",
  "description": "Bounded payments for AI agents. One API key, on-chain spend caps.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
